# Porta local do servidor webhook
PORT=3000

# Token que você escolhe (qualquer string) e configura igual no painel da Meta
VERIFY_TOKEN=escolha-uma-senha-aqui

# Token de acesso do app no Meta for Developers (WhatsApp > API Setup)
WHATSAPP_TOKEN=

# Phone Number ID do número de teste (WhatsApp > API Setup)
WHATSAPP_PHONE_NUMBER_ID=

# Seu número de WhatsApp no formato internacional sem espaços/símbolos, ex: 5511999999999
# Se definido, mensagens de outros números são ignoradas.
ALLOWED_SENDER=

# Caminho completo da planilha SGL (use barras duplas \\ no Windows)
PLANILHA_PATH=C:\\Users\\Mariana\\OneDrive\\Agente Financeiro\\SGL - 2026 Padrão Compartilhada.xlsx
